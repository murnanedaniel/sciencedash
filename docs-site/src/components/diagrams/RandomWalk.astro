---
// The thesis: research is a random walk. One path drifts and vanishes; the
// other moves forward, leaving a paper at every step. Theme-aware (Starlight
// CSS vars), minimal dark-ink-on-white.
const papers = [
  { x: 150, y: 235 },
  { x: 290, y: 250 },
  { x: 430, y: 255 },
  { x: 575, y: 258 },
  { x: 700, y: 250 },
];
---

<figure class="rw">
  <svg viewBox="0 0 760 340" role="img"
    aria-label="From a shared pool of ideas, a drifting path fades away leaving nothing, while a consolidating path moves forward and drops a paper at every step.">
    <defs>
      <linearGradient id="rw-fade" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="var(--sl-color-gray-3)" stop-opacity="0.9" />
        <stop offset="1" stop-color="var(--sl-color-gray-3)" stop-opacity="0" />
      </linearGradient>
      <marker id="rw-arrow" viewBox="0 0 10 10" refX="8" refY="5"
        markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="var(--sl-color-accent)" />
      </marker>
    </defs>

    <!-- origin -->
    <circle cx="70" cy="182" r="5" fill="var(--sl-color-text)" />
    <text x="70" y="207" class="lbl" text-anchor="middle">ideas</text>

    <!-- drift: meanders, then trails off into nothing -->
    <path d="M70,182 L140,130 200,150 250,96 310,136 360,101 410,140 455,116 500,150 545,134"
      fill="none" stroke="url(#rw-fade)" stroke-width="1.5" stroke-dasharray="2 4" stroke-linecap="round" />
    <circle cx="545" cy="134" r="3.5" fill="none" stroke="var(--sl-color-gray-3)" stroke-width="1.2" opacity="0.45" />
    <text x="150" y="86" class="lbl muted" text-anchor="start">drift — explorations that vanish</text>

    <!-- consolidation: forward, leaving an artifact each loop -->
    <path d="M70,182 L150,235 215,200 290,250 350,210 430,255 495,215 575,258 640,220 705,250"
      fill="none" stroke="var(--sl-color-accent)" stroke-width="1.8"
      stroke-linejoin="round" stroke-linecap="round" marker-end="url(#rw-arrow)" />
    {papers.map((p) => (
      <g transform={`translate(${p.x - 7}, ${p.y + 4})`}>
        <rect width="14" height="17" rx="2" fill="var(--sl-color-bg)" stroke="var(--sl-color-accent)" stroke-width="1.3" />
        <line x1="3" y1="6" x2="11" y2="6" stroke="var(--sl-color-accent)" stroke-width="1" />
        <line x1="3" y1="9.5" x2="11" y2="9.5" stroke="var(--sl-color-accent)" stroke-width="1" />
        <line x1="3" y1="13" x2="8" y2="13" stroke="var(--sl-color-accent)" stroke-width="1" />
      </g>
    ))}
    <text x="150" y="300" class="lbl accent" text-anchor="start">consolidation — every loop leaves a paper</text>
  </svg>
  <figcaption>“R&amp;D is a random walk — it just shouldn’t walk backwards.”</figcaption>
</figure>

<style>
  .rw { margin: 2rem 0 1.5rem; text-align: center; }
  .rw svg { width: 100%; max-width: 680px; height: auto; }
  .rw .lbl { font-size: 13px; fill: var(--sl-color-text); font-family: var(--sl-font-system, ui-sans-serif, sans-serif); }
  .rw .muted { fill: var(--sl-color-gray-3); }
  .rw .accent { fill: var(--sl-color-accent); font-weight: 600; }
  .rw figcaption {
    margin-top: 0.6rem;
    font-style: italic;
    font-family: Georgia, "Times New Roman", serif;
    color: var(--sl-color-gray-2);
    font-size: 1.05rem;
  }
</style>
