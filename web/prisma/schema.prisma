// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ProjectStatus {
  idea
  active
  blocked
  shipped
  parked
}

enum NarrativeReadiness {
  none
  figures_exist
  skeleton
  draftable
  drafted
  internal_review
  ready_to_submit
}

enum HypothesisStatus {
  active
  paused
  resolved
}

enum HypothesisVerdict {
  pending
  supported
  refuted
  abandoned
  spawned_paper
}

enum RunStatus {
  queued
  running
  done
  failed
}

enum MetricDirection {
  higher
  lower
}

enum ArtifactKind {
  figure
  checkpoint
  table
  slide
  dataset
  other
}

enum DecisionKind {
  promote
  park
  narrow
  spawn_paper
  resolve
  retire
  budget_escalate
  paper_status_change
  ai_patch_applied
  other
}

enum PaperStatus {
  skeleton
  draft
  internal
  arxiv
  submitted
  published
}

enum PaperSectionKind {
  intro
  related
  method
  experiments
  results
  discussion
  conclusion
  figure_list
  custom
}

enum NoteKind {
  paper
  book
  talk
  thread
  other
}

enum ProgrammeStatus {
  active
  parked
}

enum JobKind {
  wandb_pull
  github_pull
  stall_detect
  ai_review
  ai_skeleton
  ai_audit
  arxiv_fetch
  repo_quickstart
  literature_review
  project_brain
  project_brain_global
  workhorse_tick_global
  other
}

enum PromptKind {
  critical_review
  paper_skeleton
  section_polish
  outer_loop_audit
  repo_quickstart
  literature_review
  project_brain
}

enum AgentMessageSeverity {
  info
  suggestion
  decision
  blocker
}

enum AgentMessageKind {
  note
  alert
  status
  digest
  /// Command from the dashboard to a workhorse (e.g. revive_session).
  /// Body is short; payloadJson holds the structured directive.
  directive
}

model Project {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  title               String
  status              ProjectStatus @default(idea)

  description         String?
  hypothesis          String?
  figuresOfMerit      String?
  timeline            String?
  nextSteps           String?

  narrativeReadiness  NarrativeReadiness @default(none)
  narrativeReadinessNote String?
  blockers            String?

  aiAutoReviewEnabled Boolean       @default(false)

  /// Absolute path to the project's local repo on the user's machine.
  /// Used by the "chat with project" button to spawn a tmux Claude
  /// pointed at the right cwd, and by the project brain to mirror its
  /// memory files (Phase F).
  localPath           String?

  /// Project brain — Tier-2 rolling memory log (≤2K chars, FIFO key
  /// results + 15-entry decision window). Maintained by runHeartbeat;
  /// rendered in the dashboard's Plan tab; mirrored to
  /// <localPath>/.sciencedash/MEMORY_LOG.md if localPath is set.
  brainMemoryLog        String?
  /// Last project-brain cycle. Used for anti-burn (skip if too recent)
  /// and for the dashboard's "last reviewed" UI.
  brainLastHeartbeatAt  DateTime?

  /// User-authored directive consumed by the next brain heartbeat.
  /// Set via the Plan tab's directive editor; cleared (with timestamp
  /// recorded below) when the brain consumes it. Also mirrored to
  /// <localPath>/.sciencedash/HUMAN_DIRECTIVE.md when localPath is set.
  brainDirective              String?
  /// When the user last set a directive.
  brainDirectiveSetAt         DateTime?
  /// When a heartbeat last consumed a directive (cleared brainDirective).
  brainDirectiveConsumedAt    DateTime?

  /// Autonomy spectrum config (JSON). Brain dispatch tools consult this
  /// before firing. Shape:
  ///   { auto: ["restart_run", ...], propose: [...], ask: [...],
  ///     spendCapGpuH: 100, spendCapTokensUsd: 1.0 }
  /// Anything not listed defaults to "ask" — conservative.
  autonomyJson          String?

  /// Per-project cadence overrides (seconds) for the autonomy loops.
  /// Null = use the worker's global default (DEFAULT_BRAIN_INTERVAL_SEC,
  /// DEFAULT_WORKHORSE_INTERVAL_SEC). 0 = paused (worker tick skips this
  /// project entirely). Only applies when the project's autonomy bucket
  /// for the corresponding action class is `auto` or `propose`; an
  /// `ask` bucket already prevents the loop from firing.
  brainIntervalSec      Int?
  workhorseIntervalSec  Int?

  /// Optional roll-up to a Programme — a coordinated cluster of related
  /// projects sharing a publication strategy (e.g. "ColliderML tracking",
  /// "Foundation-model ingredients"). One project belongs to at most one
  /// programme; null = unprogrammed. onDelete:SetNull so deleting a
  /// programme detaches its children, doesn't cascade.
  programmeId         String?
  programme           Programme?    @relation(fields: [programmeId], references: [id], onDelete: SetNull)

  tags                Tag[]         @relation("ProjectTags")

  hypotheses          Hypothesis[]
  metricDefinitions   ProjectMetricDefinition[]
  checkIns            CheckIn[]
  artifacts           Artifact[]
  decisions           Decision[]
  papers              Paper[]
  notes               NoteProject[]
  wandbSources        WandbSource[]
  repoLinks           RepoLink[]
  agentMessages       AgentMessage[]
  workhorses          Workhorse[]
  threads             Thread[]

  @@index([programmeId])
}

model WandbSource {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  entity      String
  name        String  // "project" in W&B terms — renamed to avoid collision

  runs        Run[]

  @@unique([projectId, entity, name])
}

model RepoLink {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now())

  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url                 String
  label               String?
  cachedLastCommitSha String?
  cachedLastCommitAt  DateTime?

  @@unique([projectId, url])
}

/// A coordinated cluster of related projects sharing a publication
/// strategy. seed.md §5/§6 — "ColliderML exploitation programme",
/// "Foundation-model ingredient programme", etc. Lives above Project,
/// orthogonal to Tag. One project belongs to at most one programme;
/// detaching is `Project.programmeId = null`.
model Programme {
  id                     String           @id @default(cuid())
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  /// Display name. Unique to keep the URL/list/palette unambiguous.
  name                   String           @unique
  /// Free-form markdown — the programme thesis. "What story is this
  /// programme trying to tell, across N projects?"
  description            String?
  /// Comma-separated venue list (e.g. "JINST, Comput Phys Comm, NeurIPS").
  /// Free text for now; can become a relation later.
  targetVenues           String?
  /// Programme-level FOM family — what counts as winning across the
  /// children. Free markdown.
  figuresOfMerit         String?
  status                 ProgrammeStatus  @default(active)
  /// One-line state for the /today rail or rollup ("blocked on X",
  /// "tracking 3 papers").
  narrativeReadinessNote String?

  projects               Project[]
}

model Tag {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  name      String    @unique

  projects  Project[] @relation("ProjectTags")
}

model Hypothesis {
  id                      String            @id @default(cuid())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  projectId               String
  project                 Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title                   String
  statement               String?
  status                  HypothesisStatus  @default(active)
  verdict                 HypothesisVerdict @default(pending)

  computeBudgetGpuHours   Float             @default(10)

  resolvedAt              DateTime?

  runs                    Run[]
  papers                  HypothesisPaper[]
}

model Run {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  hypothesisId     String
  hypothesis       Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  name             String
  wandbRunId       String?
  wandbSourceId    String?
  wandbSource      WandbSource? @relation(fields: [wandbSourceId], references: [id], onDelete: SetNull)
  status           RunStatus @default(done)
  startedAt        DateTime?
  endedAt          DateTime?
  computeGpuHours  Float     @default(0)
  notes            String?

  metrics          Metric[]
  artifacts        Artifact[]
}

model ProjectMetricDefinition {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())

  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  unit        String?
  direction   MetricDirection @default(higher)
  isPrimary   Boolean         @default(false)
  threshold   Float?

  metrics     Metric[]

  @@unique([projectId, name])
}

model Metric {
  id           String                   @id @default(cuid())
  createdAt    DateTime                 @default(now())

  runId        String
  run          Run                      @relation(fields: [runId], references: [id], onDelete: Cascade)

  definitionId String
  definition   ProjectMetricDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  value        Float

  @@unique([runId, definitionId])
}

model Artifact {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  kind        ArtifactKind  @default(other)
  path        String
  caption     String?

  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  runId       String?
  run         Run?          @relation(fields: [runId], references: [id], onDelete: Cascade)

  paperId     String?
  paper       Paper?        @relation(fields: [paperId], references: [id], onDelete: Cascade)

  paperSectionId String?
  paperSection PaperSection? @relation(fields: [paperSectionId], references: [id], onDelete: SetNull)
}

model Paper {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  title               String
  abstract            String?
  status              PaperStatus   @default(skeleton)

  arxivId             String?
  doi                 String?
  venue               String?
  plannedVenue        String?
  submittedAt         DateTime?
  publishedAt         DateTime?

  primaryProjectId    String?
  primaryProject      Project?      @relation(fields: [primaryProjectId], references: [id], onDelete: SetNull)

  sections            PaperSection[]
  hypotheses          HypothesisPaper[]
  artifacts           Artifact[]
}

model PaperSection {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  paperId     String
  paper       Paper             @relation(fields: [paperId], references: [id], onDelete: Cascade)

  kind        PaperSectionKind  @default(custom)
  title       String
  contentMd   String            @default("")
  order       Int               @default(0)

  artifacts   Artifact[]
}

model HypothesisPaper {
  hypothesisId String
  hypothesis   Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  paperId      String
  paper        Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@id([hypothesisId, paperId])
}

model Note {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  kind       NoteKind       @default(paper)
  title      String
  authors    String?
  url        String?
  arxivId    String?
  summaryMd  String?
  takeaway   String?

  projects   NoteProject[]
}

model NoteProject {
  noteId     String
  note       Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([noteId, projectId])
}

model JobRun {
  id           String    @id @default(cuid())
  kind         JobKind
  title        String?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  ok           Boolean?
  error        String?
  payloadJson  String?
  messagesJson String?
  costUsd      Float?

  projectId    String?
}

model PromptTemplate {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  kind       PromptKind  @unique
  version    Int         @default(1)
  bodyMd     String
}


model Decision {
  id           String         @id @default(cuid())
  at           DateTime       @default(now())

  kind         DecisionKind
  subjectType  String
  subjectId    String
  rationale    String?

  /// Optional JSON array of evidence pointers, e.g.
  /// [{ "type": "note", "id": "cmoii…" }, { "type": "checkIn", "id": "cmo…" }].
  /// Lets the dashboard render decision provenance as clickable links
  /// instead of having to parse references out of the rationale prose.
  evidenceIdsJson  String?

  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now())

  scope               String
  /// Shape of the check-in. Lets the digest agent render plan-adoption
  /// vs routine-progress vs blocker-escalation differently. Free-form;
  /// canonical values: routine | plan | blocker | retro | other.
  kind                String    @default("routine")
  projectId           String?
  project             Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bodyMd              String
  source              String    @default("manual")
  proposedPatchJson   String?
}

model Workhorse {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Hostname or stable workhorse identifier ("perlmutter", "vast-h100-3", etc.).
  host            String
  /// tmux session name on the host. Convention: `sd-<projectId-prefix>`.
  sessionName     String

  /// Last beat from the cron-driven sync daemon. Indicates `host_reachable`.
  lastHeartbeat   DateTime?
  /// Last beat from a Claude tool call. Indicates `claude_active`.
  lastClaudeBeat  DateTime?

  /// Workhorse-side config snapshot (JSON). Helpful for debugging.
  configJson      String?

  @@unique([host, sessionName])
  @@index([host])
  @@index([projectId])
}

model AgentMessage {
  id            String                @id @default(cuid())
  createdAt     DateTime              @default(now())

  projectId     String
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Origin identifier — convention: "project-brain", "global-brain",
  // "workhorse-<host>:sd-<projectId>", "local-claude", "review-agent",
  // "sync-agent". Free-form to support future sources without migrations.
  source        String

  kind          AgentMessageKind      @default(note)
  severity      AgentMessageSeverity  @default(info)

  body          String
  /// Optional structured payload (e.g. action params for propose-acts).
  payloadJson   String?

  readAt        DateTime?

  @@index([projectId, createdAt])
  @@index([projectId, readAt])
}

/// Persisted record of a chat between the user and a global-brain advisor
/// session (a local Claude REPL running with the ScienceDash MCP loaded).
///
/// The chat Claude calls `submit_brain_chat` at end-of-session with the
/// full markdown transcript. The global brain heartbeat then sweeps rows
/// where summaryMd is null, summarises them in 3–6 bullets, and writes
/// the summary back so future sessions inherit continuity through the
/// CHAT_CONTEXT primer.
model BrainChat {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  title         String
  /// Full conversation as markdown with speaker turns.
  transcriptMd  String
  /// 3–6 bullet summary written by the heartbeat sweep. Null until summarised.
  summaryMd     String?
  summarizedAt  DateTime?

  @@index([createdAt])
  @@index([summarizedAt])
}

/// A Claude Code session transcript ingested from any machine — the ambient
/// context layer. Every `claude` session (terminal or remote-controlled, on
/// homebox / Perlmutter / laptop) ships its JSONL here so conversations are
/// searchable across machines and sessions. Search runs over `bodyText` via a
/// raw FTS5 table (ThreadFTS); `turns` keep the conversation for rendering.
model Thread {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// Claude Code session UUID (the .jsonl filename). Unique across machines.
  sessionId    String    @unique
  /// Hostname the session ran on (homebox / perlmutter / laptop).
  machine      String
  /// The session's working directory (from the transcript events).
  cwd          String
  /// Normalized git remote of cwd (host/org/repo) — the robust, cross-machine
  /// project key (a repo has the same remote on every machine).
  gitRemote    String?
  /// Auto-generated session title (the `ai-title` event), if any.
  title        String?

  /// Project matched by cwd -> Project.localPath. Null = unassociated.
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  firstAt      DateTime?
  lastAt       DateTime?
  turnCount    Int       @default(0)
  /// Redacted, concatenated user+assistant+tool text for full-text search.
  bodyText     String    @default("")
  /// Lines shipped so far — incremental ingest dedup (the shipper also tracks
  /// this locally; stored here as the server's source of truth).
  shippedLines Int       @default(0)

  turns        Turn[]

  @@index([projectId])
  @@index([machine])
  @@index([lastAt])
}

/// One turn (user / assistant / tool) within a Thread, for rendering the
/// conversation. Full-text search runs over Thread.bodyText, not per-turn.
model Turn {
  id        String    @id @default(cuid())
  threadId  String
  thread    Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)

  idx       Int
  role      String    // user | assistant | tool
  text      String
  toolName  String?
  at        DateTime?

  @@unique([threadId, idx])
  @@index([threadId])
}
