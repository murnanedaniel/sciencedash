// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ProjectStatus {
  idea
  active
  blocked
  shipped
  parked
}

enum NarrativeReadiness {
  none
  figures_exist
  skeleton
  draftable
  drafted
  internal_review
  ready_to_submit
}

enum HypothesisStatus {
  active
  paused
  resolved
}

enum HypothesisVerdict {
  pending
  supported
  refuted
  abandoned
  spawned_paper
}

enum RunStatus {
  queued
  running
  done
  failed
}

enum MetricDirection {
  higher
  lower
}

enum ArtifactKind {
  figure
  checkpoint
  table
  slide
  dataset
  other
}

enum DecisionKind {
  promote
  park
  narrow
  spawn_paper
  resolve
  retire
  budget_escalate
  paper_status_change
  ai_patch_applied
  other
}

enum PaperStatus {
  skeleton
  draft
  internal
  arxiv
  submitted
  published
}

enum PaperSectionKind {
  intro
  related
  method
  experiments
  results
  discussion
  conclusion
  figure_list
  custom
}

enum NoteKind {
  paper
  book
  talk
  thread
  other
}

enum JobKind {
  wandb_pull
  github_pull
  stall_detect
  ai_review
  ai_skeleton
  ai_audit
  arxiv_fetch
  other
}

enum PromptKind {
  critical_review
  paper_skeleton
  section_polish
  outer_loop_audit
}

model Project {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  title               String
  status              ProjectStatus @default(idea)

  description         String?
  hypothesis          String?
  figuresOfMerit      String?
  timeline            String?
  nextSteps           String?

  narrativeReadiness  NarrativeReadiness @default(none)
  narrativeReadinessNote String?
  blockers            String?

  aiAutoReviewEnabled Boolean       @default(false)

  tags                Tag[]         @relation("ProjectTags")

  hypotheses          Hypothesis[]
  metricDefinitions   ProjectMetricDefinition[]
  checkIns            CheckIn[]
  artifacts           Artifact[]
  decisions           Decision[]
  papers              Paper[]
  notes               NoteProject[]
  wandbSources        WandbSource[]
  repoLinks           RepoLink[]
}

model WandbSource {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  entity      String
  name        String  // "project" in W&B terms — renamed to avoid collision

  runs        Run[]

  @@unique([projectId, entity, name])
}

model RepoLink {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now())

  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url                 String
  label               String?
  cachedLastCommitSha String?
  cachedLastCommitAt  DateTime?

  @@unique([projectId, url])
}

model Tag {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  name      String    @unique

  projects  Project[] @relation("ProjectTags")
}

model Hypothesis {
  id                      String            @id @default(cuid())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  projectId               String
  project                 Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title                   String
  statement               String?
  status                  HypothesisStatus  @default(active)
  verdict                 HypothesisVerdict @default(pending)

  computeBudgetGpuHours   Float             @default(10)

  resolvedAt              DateTime?

  runs                    Run[]
  papers                  HypothesisPaper[]
}

model Run {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  hypothesisId     String
  hypothesis       Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  name             String
  wandbRunId       String?
  wandbSourceId    String?
  wandbSource      WandbSource? @relation(fields: [wandbSourceId], references: [id], onDelete: SetNull)
  status           RunStatus @default(done)
  startedAt        DateTime?
  endedAt          DateTime?
  computeGpuHours  Float     @default(0)
  notes            String?

  metrics          Metric[]
  artifacts        Artifact[]
}

model ProjectMetricDefinition {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())

  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  unit        String?
  direction   MetricDirection @default(higher)
  isPrimary   Boolean         @default(false)
  threshold   Float?

  metrics     Metric[]

  @@unique([projectId, name])
}

model Metric {
  id           String                   @id @default(cuid())
  createdAt    DateTime                 @default(now())

  runId        String
  run          Run                      @relation(fields: [runId], references: [id], onDelete: Cascade)

  definitionId String
  definition   ProjectMetricDefinition  @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  value        Float

  @@unique([runId, definitionId])
}

model Artifact {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  kind        ArtifactKind  @default(other)
  path        String
  caption     String?

  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  runId       String?
  run         Run?          @relation(fields: [runId], references: [id], onDelete: Cascade)

  paperId     String?
  paper       Paper?        @relation(fields: [paperId], references: [id], onDelete: Cascade)

  paperSectionId String?
  paperSection PaperSection? @relation(fields: [paperSectionId], references: [id], onDelete: SetNull)
}

model Paper {
  id                  String        @id @default(cuid())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  title               String
  abstract            String?
  status              PaperStatus   @default(skeleton)

  arxivId             String?
  doi                 String?
  venue               String?
  plannedVenue        String?
  submittedAt         DateTime?
  publishedAt         DateTime?

  primaryProjectId    String?
  primaryProject      Project?      @relation(fields: [primaryProjectId], references: [id], onDelete: SetNull)

  sections            PaperSection[]
  hypotheses          HypothesisPaper[]
  artifacts           Artifact[]
}

model PaperSection {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  paperId     String
  paper       Paper             @relation(fields: [paperId], references: [id], onDelete: Cascade)

  kind        PaperSectionKind  @default(custom)
  title       String
  contentMd   String            @default("")
  order       Int               @default(0)

  artifacts   Artifact[]
}

model HypothesisPaper {
  hypothesisId String
  hypothesis   Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  paperId      String
  paper        Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())

  @@id([hypothesisId, paperId])
}

model Note {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  kind       NoteKind       @default(paper)
  title      String
  authors    String?
  url        String?
  arxivId    String?
  summaryMd  String?
  takeaway   String?

  projects   NoteProject[]
}

model NoteProject {
  noteId     String
  note       Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([noteId, projectId])
}

model JobRun {
  id           String    @id @default(cuid())
  kind         JobKind
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  ok           Boolean?
  error        String?
  payloadJson  String?

  projectId    String?
}

model PromptTemplate {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  kind       PromptKind  @unique
  version    Int         @default(1)
  bodyMd     String
}


model Decision {
  id           String         @id @default(cuid())
  at           DateTime       @default(now())

  kind         DecisionKind
  subjectType  String
  subjectId    String
  rationale    String?

  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now())

  scope               String
  projectId           String?
  project             Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bodyMd              String
  source              String    @default("manual")
  proposedPatchJson   String?
}
