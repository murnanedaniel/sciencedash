# ScienceDash environment variables — copy to .env before running.
#
# Auth section is REQUIRED (the app proxy will throw on first request
# if any of the four values are missing). Everything below it is
# optional integration creds.

# === Database ===
DATABASE_URL="file:./dev.db"

# === Auth (set ONCE per deployment, never rotate on a schedule) ===
#
# Generate the four values like this (one terminal, one block):
#
#   PASSWORD='whatever-password-you-want'
#   echo "SCIENCEDASH_AUTH_TOKEN=$(openssl rand -base64 32 | tr -d '\n=' | tr '/+' '_-')"
#   echo "SCIENCEDASH_SESSION_SECRET=$(openssl rand -base64 48 | tr -d '\n')"
#   SALT="$(openssl rand -base64 16 | tr -d '\n')"
#   echo "SCIENCEDASH_PASSWORD_SALT=$SALT"
#   echo "SCIENCEDASH_AUTH_PASSWORD_HASH=$(printf '%s%s' "$PASSWORD" "$SALT" | sha256sum | awk '{print $1}')"
#
# Then paste the four resulting lines below.
#
# AUTH_TOKEN: literal string sync.py and workhorse Claudes send as
#   `Authorization: Bearer <this>`. Keep it secret; share only via
#   ~/.sciencedash/auth.env on each workhorse host.
# SESSION_SECRET: HMAC key for browser session cookies. Rotating this
#   logs every browser out (cookies become invalid).
# PASSWORD_SALT + PASSWORD_HASH: store the user's password as
#   sha256(password + salt), not plaintext.

SCIENCEDASH_AUTH_TOKEN=""
SCIENCEDASH_SESSION_SECRET=""
SCIENCEDASH_PASSWORD_SALT=""
SCIENCEDASH_AUTH_PASSWORD_HASH=""

# === Optional: data ingest ===
WANDB_API_KEY=""
GITHUB_PAT=""
SCIENCEDASH_REPO_TEMPLATE=""

# === Optional: networking ===
# Public origin (scheme + host) the dashboard is reachable at, e.g.
# https://sciencedash.example.com. Used when generating workhorse / brain-chat
# bootstrap scripts. Falls back to X-Forwarded-Host / Host if unset.
# SCIENCEDASH_BASE_URL=""
# Extra dev origins (comma-separated hostnames) to allow behind a reverse proxy.
# SCIENCEDASH_ALLOWED_DEV_ORIGINS=""
# Listen port for the worker's internal fetch (defaults to 3000).
# PORT="3000"

# === Optional: auto-deploy (author-specific; OFF unless enabled) ===
# Pull-from-origin/main timer + the /settings deploy widget. Most users leave
# this disabled. Requires a git checkout with GitHub CI and the gh CLI.
# SCIENCEDASH_AUTO_DEPLOY_ENABLED=""        # "1" or "true" to enable
# SCIENCEDASH_REPO_SLUG=""                  # your-org/your-repo (for CI gating)
# SCIENCEDASH_REPO_ROOT=""                  # absolute path to your checkout
# SCIENCEDASH_STATE_DIR=""                  # defaults to ~/.sciencedash
